[Unit]
Description=WireGuard captive admin web UI
After=network-online.target docker.service
Wants=network-online.target docker.service

[Service]
Type=simple
EnvironmentFile=/etc/wg-captive-agent.env
ExecStart=/usr/bin/node /usr/local/lib/wg-captive-agent/wg-captive-admin.js
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target

