# WireGuard interface on this server.
WG_INTERFACE=wg0

# ipset name used by the agent.
IPSET_NAME=wg_expired

# Public IP of your external captive web server.
# HTTP requests from expired routers are redirected to PORTAL_IP:80.
# Portal HTTPS, if used, must have a certificate valid for this IP address.
PORTAL_IP=1.1.1.1


# SQLite state database and runtime firewall export.
STATE_DB=/etc/wg-captive-agent.db
EXPIRED_FILE=/etc/wg-captive-expired.txt

# API mode. Uncomment to fetch expired IPs from a central billing system.
# EXPIRED_URL=https://billing.example.com/api/servers/vn-hcm-01/expired-ips
# API_TOKEN=replace-me

# Seconds between syncs when running as a daemon.
SYNC_INTERVAL=30

# Allow DNS port 53 by default so captive-check domains can resolve.
# Set to 1 only if you use a separate DNS spoof/proxy captive flow.
BLOCK_DNS=0

# Allow DNS-over-TLS by default for routers configured with DoT.
BLOCK_DOT=0

# Admin web UI. Set a strong password before exposing the UI.
ADMIN_HOST=0.0.0.0
ADMIN_PORT=51822
ADMIN_PASSWORD=change-this-password
# Optional bearer token for central management API calls.
ADMIN_API_TOKEN=


# wg-easy JSON database. Usually /etc/wireguard/wg0.json on the wg-easy host/container volume.
WG_EASY_JSON=/etc/wireguard/wg0.json
TELEGRAM_BACKUP_ENABLED=1
TELEGRAM_BOT_TOKEN=
AUTO_BACKUP_TIMES=02:00
AUTO_BACKUP_ENABLED=0
# Daily expiry check times. At these times, due clients are marked expired and firewall is synced.
EXPIRY_CHECK_TIMES=00:10,12:10
EXPIRY_CHECK_ENABLED=1
SERVER_NAME=wg-server-01
TELEGRAM_CHAT_ID=
SERVER_PUBLIC_IP=203.0.113.20
BACKUP_DIR=/var/backups/wg-captive
WG_EASY_CONTAINER=wg-easy
WG_EASY_CONTAINER_JSON=/etc/wireguard/wg0.json
WG_EASY_CONF=/etc/wireguard/wg0.conf
WG_EASY_CONTAINER_CONF=/etc/wireguard/wg0.conf
DOCKER_DNS_IP=172.17.0.1

# Relay mode. Import exit-node WireGuard .conf from admin UI.
RELAY_ENABLED=0
RELAY_EXIT_IF=wg-exit
# Client subnet used by relay route rules. Change in admin Settings if needed.
RELAY_CLIENT_SUBNET=10.8.0.0/24
RELAY_ROUTE_TABLE=200
RELAY_EXIT_CONF=/etc/wg-captive-relay-exit.conf
RELAY_ROUTE_FLAG=/etc/wg-captive-relay.enabled
