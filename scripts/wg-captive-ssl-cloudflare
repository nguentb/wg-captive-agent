#!/usr/bin/env bash
set -euo pipefail

CONFIG_FILE="/etc/wg-captive-ssl-cloudflare.env"
AGENT_ENV_FILE="/etc/wg-captive-agent.env"
ADMIN_PUBLIC_PORT="51822"
ADMIN_UPSTREAM_HOST="127.0.0.1"
ADMIN_UPSTREAM_PORT="51824"
NGINX_SITE_NAME="wg-captive-admin"
CF_CREDENTIALS_FILE="/etc/letsencrypt/cloudflare-${NGINX_SITE_NAME}.ini"
RENEW_HOOK="/etc/letsencrypt/renewal-hooks/deploy/wg-captive-nginx-reload"

log() { printf '[wg-captive ssl] %s\n' "$*"; }
fail() { printf '[wg-captive ssl] ERROR: %s\n' "$*" >&2; exit 1; }

usage() {
  cat <<'EOF'
Usage:
  sudo captive_ssl_cloudflare

The tool asks for Cloudflare DNS-01 certificate info, then configures HTTPS for wg-captive-admin/API:
  https://domain:51822 -> wg-captive-admin on 127.0.0.1:51824

Cloudflare token needs:
  Zone.Zone:Read
  Zone.DNS:Edit
  Scope: the zone that contains the domain
EOF
}

shell_escape() {
  printf "'%s'" "$(printf '%s' "$1" | sed "s/'/'\\\\''/g")"
}

prompt_required() {
  local var_name="$1"
  local label="$2"
  local secret="${3:-0}"
  local value=""
  while [[ -z "$value" ]]; do
    if [[ "$secret" == "1" ]]; then
      printf '%s: ' "$label" >&2
      read -r -s value
      printf '\n' >&2
    else
      read -r -p "${label}: " value
    fi
    value="$(printf '%s' "$value" | sed 's/^ *//;s/ *$//')"
  done
  printf -v "$var_name" '%s' "$value"
}

prompt_default() {
  local var_name="$1"
  local label="$2"
  local default_value="$3"
  local value=""
  read -r -p "${label} [${default_value}]: " value
  value="$(printf '%s' "$value" | sed 's/^ *//;s/ *$//')"
  [[ -n "$value" ]] || value="$default_value"
  printf -v "$var_name" '%s' "$value"
}

valid_port() {
  [[ "$1" =~ ^[0-9]+$ ]] && [[ "$1" -ge 1 ]] && [[ "$1" -le 65535 ]]
}

set_env_value() {
  local file="$1"
  local key="$2"
  local value="$3"
  local escaped
  escaped="$(shell_escape "$value")"
  install -d -m 0755 "$(dirname "$file")"
  touch "$file"
  if grep -qE "^${key}=" "$file"; then
    sed -i "s|^${key}=.*|${key}=${escaped}|" "$file"
  else
    printf '%s=%s\n' "$key" "$escaped" >> "$file"
  fi
}

[[ "${1:-}" == "-h" || "${1:-}" == "--help" ]] && { usage; exit 0; }
[[ "${EUID}" -eq 0 ]] || fail "Run as root with sudo"

prompt_required DOMAIN "Domain"
prompt_required EMAIL "Email"
prompt_required CF_API_TOKEN "Cloudflare API token" 1
prompt_default ADMIN_PUBLIC_PORT "wg-captive admin public HTTPS port" "$ADMIN_PUBLIC_PORT"
prompt_default ADMIN_UPSTREAM_PORT "wg-captive admin internal HTTP port" "$ADMIN_UPSTREAM_PORT"
[[ "$DOMAIN" =~ ^[A-Za-z0-9._-]+$ ]] || fail "Domain contains invalid characters"
[[ "$EMAIL" == *@*.* ]] || fail "Email looks invalid"
valid_port "$ADMIN_PUBLIC_PORT" || fail "Invalid admin public port"
valid_port "$ADMIN_UPSTREAM_PORT" || fail "Invalid admin internal port"
if [[ "$ADMIN_PUBLIC_PORT" == "$ADMIN_UPSTREAM_PORT" ]]; then
  fail "Admin public port and internal port must be different because nginx will listen on the public port"
fi
if ! command -v apt-get >/dev/null 2>&1; then
  fail "This installer currently supports Debian/Ubuntu with apt-get"
fi

log "Installing nginx, certbot and Cloudflare DNS plugin"
apt-get update
DEBIAN_FRONTEND=noninteractive apt-get install -y nginx certbot python3-certbot-dns-cloudflare

install -d -m 0755 "$(dirname "$CONFIG_FILE")"
cat > "$CONFIG_FILE" <<EOF
DOMAIN=$(shell_escape "$DOMAIN")
EMAIL=$(shell_escape "$EMAIL")
ADMIN_PUBLIC_PORT=$(shell_escape "$ADMIN_PUBLIC_PORT")
ADMIN_UPSTREAM_HOST=$(shell_escape "$ADMIN_UPSTREAM_HOST")
ADMIN_UPSTREAM_PORT=$(shell_escape "$ADMIN_UPSTREAM_PORT")
NGINX_SITE_NAME=$(shell_escape "$NGINX_SITE_NAME")
CF_CREDENTIALS_FILE=$(shell_escape "$CF_CREDENTIALS_FILE")
EOF
chmod 600 "$CONFIG_FILE"

install -d -m 0700 "$(dirname "$CF_CREDENTIALS_FILE")"
cat > "$CF_CREDENTIALS_FILE" <<EOF
dns_cloudflare_api_token = ${CF_API_TOKEN}
EOF
chmod 600 "$CF_CREDENTIALS_FILE"

log "Requesting Let's Encrypt certificate for ${DOMAIN} using Cloudflare DNS-01"
certbot certonly \
  --dns-cloudflare \
  --dns-cloudflare-credentials "$CF_CREDENTIALS_FILE" \
  --dns-cloudflare-propagation-seconds 60 \
  -d "$DOMAIN" \
  --email "$EMAIL" \
  --agree-tos \
  --non-interactive \
  --keep-until-expiring

log "Moving wg-captive-admin to internal ${ADMIN_UPSTREAM_HOST}:${ADMIN_UPSTREAM_PORT}"
set_env_value "$AGENT_ENV_FILE" "ADMIN_HOST" "$ADMIN_UPSTREAM_HOST"
set_env_value "$AGENT_ENV_FILE" "ADMIN_PORT" "$ADMIN_UPSTREAM_PORT"

if command -v systemctl >/dev/null 2>&1; then
  systemctl restart wg-captive-admin || true
fi

NGINX_CONF="/etc/nginx/sites-available/${NGINX_SITE_NAME}"
log "Writing nginx custom-port HTTPS proxy ${NGINX_CONF}"
cat > "$NGINX_CONF" <<EOF
server {
    listen ${ADMIN_PUBLIC_PORT} ssl http2;
    listen [::]:${ADMIN_PUBLIC_PORT} ssl http2;
    server_name ${DOMAIN};

    ssl_certificate /etc/letsencrypt/live/${DOMAIN}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/${DOMAIN}/privkey.pem;

    add_header X-Content-Type-Options nosniff always;
    add_header Referrer-Policy no-referrer always;

    location / {
        proxy_pass http://${ADMIN_UPSTREAM_HOST}:${ADMIN_UPSTREAM_PORT};
        proxy_http_version 1.1;
        proxy_set_header Host \$host;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header Upgrade \$http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}
EOF

ln -sf "$NGINX_CONF" "/etc/nginx/sites-enabled/${NGINX_SITE_NAME}"

install -d -m 0755 "$(dirname "$RENEW_HOOK")"
cat > "$RENEW_HOOK" <<'EOF'
#!/usr/bin/env bash
set -e
systemctl reload nginx
systemctl restart wg-captive-admin || true
EOF
chmod 755 "$RENEW_HOOK"

log "Testing nginx config"
nginx -t

log "Reloading services"
systemctl enable --now nginx
systemctl reload nginx
systemctl restart wg-captive-admin || true

log "Done"
log "Saved SSL config: ${CONFIG_FILE}"
log "wg-captive admin HTTPS: https://${DOMAIN}:${ADMIN_PUBLIC_PORT}"
log "WireGuard UDP remains unchanged, for example ${DOMAIN}:51820/udp"
