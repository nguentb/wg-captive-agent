#!/usr/bin/env bash
set -euo pipefail

CONFIG_FILE="${CONFIG_FILE:-/etc/wg-captive-agent.env}"

if [[ -f "$CONFIG_FILE" ]]; then
  # shellcheck disable=SC1090
  source "$CONFIG_FILE"
fi

WG_INTERFACE="${WG_INTERFACE:-wg0}"
IPSET_NAME="${IPSET_NAME:-wg_expired}"
PORTAL_IP="${PORTAL_IP:-}"
EXPIRED_FILE="${EXPIRED_FILE:-}"
EXPIRED_URL="${EXPIRED_URL:-}"
API_TOKEN="${API_TOKEN:-}"
SYNC_INTERVAL="${SYNC_INTERVAL:-30}"
BLOCK_DNS="${BLOCK_DNS:-0}"
BLOCK_DOT="${BLOCK_DOT:-0}"
WG_EASY_CONTAINER="${WG_EASY_CONTAINER:-}"
DOCKER_DNS_IP="${DOCKER_DNS_IP:-172.17.0.1}"
RELAY_EXIT_IF="${RELAY_EXIT_IF:-wg-exit}"
RELAY_CLIENT_SUBNET="${RELAY_CLIENT_SUBNET:-10.8.0.0/24}"
RELAY_ROUTE_TABLE="${RELAY_ROUTE_TABLE:-200}"
RELAY_EXIT_CONF="${RELAY_EXIT_CONF:-/etc/wg-captive-relay-exit.conf}"
RELAY_ROUTE_FLAG="${RELAY_ROUTE_FLAG:-/etc/wg-captive-relay.enabled}"

NAT_CHAIN="WG_CAPTIVE_NAT"
FILTER_CHAIN="WG_CAPTIVE_FILTER"
NETNS_PID=""

usage() {
  cat <<'EOF'
Usage: wg-captive-agent [run|sync|cleanup|status|relay-enable|relay-disable|relay-delete-config|relay-on|relay-off|relay-status|relay-tunnel-up|relay-tunnel-down|relay-restart|relay-restore]

Commands:
  run      Sync expired peers in a loop and keep firewall rules installed.
  sync     Sync expired peers once and install firewall rules.
  cleanup  Remove wg-captive-agent iptables chains and ipset.
  status   Print current ipset and firewall chain status.
  relay-*  Manage relay tunnel and route inside wg-easy container.
EOF
}

die() {
  echo "wg-captive-agent: $*" >&2
  exit 1
}

require_root() {
  [[ "${EUID}" -eq 0 ]] || die "must run as root"
}

require_config() {
  [[ -n "$PORTAL_IP" ]] || die "PORTAL_IP is required"
}

resolve_netns() {
  NETNS_PID=""
  if [[ -n "$WG_EASY_CONTAINER" && "$WG_EASY_CONTAINER" != "host" ]]; then
    command -v docker >/dev/null 2>&1 || die "docker is required when WG_EASY_CONTAINER is set"
    command -v nsenter >/dev/null 2>&1 || die "nsenter is required when WG_EASY_CONTAINER is set; install util-linux"
    NETNS_PID="$(docker inspect -f '{{.State.Pid}}' "$WG_EASY_CONTAINER" 2>/dev/null || true)"
    [[ -n "$NETNS_PID" && "$NETNS_PID" != "0" ]] || die "container '$WG_EASY_CONTAINER' is not running"
  fi
}

net_exec() {
  if [[ -n "$NETNS_PID" ]]; then
    nsenter -t "$NETNS_PID" -n "$@"
  else
    "$@"
  fi
}

ipt() {
  net_exec iptables "$@"
}

ips() {
  net_exec ipset "$@"
}

ensure_tools() {
  command -v iptables >/dev/null 2>&1 || die "iptables is required on host"
  command -v ipset >/dev/null 2>&1 || die "ipset is required on host"
  resolve_netns
  net_exec iptables -V >/dev/null 2>&1 || die "iptables cannot run in target network namespace"
  net_exec ipset -V >/dev/null 2>&1 || die "ipset cannot run in target network namespace"
}

iptables_has_rule() {
  local table="$1"
  shift
  ipt -t "$table" -C "$@" >/dev/null 2>&1
}

iptables_append_once() {
  local table="$1"
  shift
  if ! iptables_has_rule "$table" "$@"; then
    ipt -t "$table" -A "$@"
  fi
}

iptables_insert_once() {
  local table="$1"
  shift
  if ! iptables_has_rule "$table" "$@"; then
    ipt -t "$table" -I "$@"
  fi
}

ensure_chain() {
  local table="$1"
  local chain="$2"
  if ! ipt -t "$table" -nL "$chain" >/dev/null 2>&1; then
    ipt -t "$table" -N "$chain"
  fi
}

ensure_firewall() {
  ips create "$IPSET_NAME" hash:ip -exist

  ensure_chain nat "$NAT_CHAIN"
  ensure_chain filter "$FILTER_CHAIN"

  iptables_append_once nat PREROUTING -i "$WG_INTERFACE" -m set --match-set "$IPSET_NAME" src -j "$NAT_CHAIN"
  iptables_append_once nat PREROUTING -m set --match-set "$IPSET_NAME" src -j "$NAT_CHAIN"
  iptables_insert_once filter FORWARD -i "$WG_INTERFACE" -m set --match-set "$IPSET_NAME" src -j "$FILTER_CHAIN"
  iptables_insert_once filter FORWARD -m set --match-set "$IPSET_NAME" src -j "$FILTER_CHAIN"

  ipt -t nat -F "$NAT_CHAIN"
  ipt -t filter -F "$FILTER_CHAIN"

  ipt -t nat -A "$NAT_CHAIN" -p tcp --dport 80 -j DNAT --to-destination "${PORTAL_IP}:80"

  ipt -t filter -A "$FILTER_CHAIN" -d "$PORTAL_IP" -p tcp --dport 80 -j ACCEPT
  ipt -t filter -A "$FILTER_CHAIN" -d "$PORTAL_IP" -p tcp --dport 443 -j ACCEPT

  if [[ "$BLOCK_DNS" == "1" ]]; then
    ipt -t filter -A "$FILTER_CHAIN" -p udp --dport 53 -j REJECT
    ipt -t filter -A "$FILTER_CHAIN" -p tcp --dport 53 -j REJECT
  else
    ipt -t filter -A "$FILTER_CHAIN" -p udp --dport 53 -j ACCEPT
    ipt -t filter -A "$FILTER_CHAIN" -p tcp --dport 53 -j ACCEPT
  fi

  if [[ "$BLOCK_DOT" == "1" ]]; then
    ipt -t filter -A "$FILTER_CHAIN" -p tcp --dport 853 -j REJECT
  else
    ipt -t filter -A "$FILTER_CHAIN" -p tcp --dport 853 -j ACCEPT
  fi

  ipt -t filter -A "$FILTER_CHAIN" -p tcp --dport 443 -j REJECT
  ipt -t filter -A "$FILTER_CHAIN" -j REJECT
}


relay_exec() {
  if [[ -n "$WG_EASY_CONTAINER" && "$WG_EASY_CONTAINER" != "host" ]]; then
    command -v docker >/dev/null 2>&1 || die "docker is required when WG_EASY_CONTAINER is set"
    docker exec "$WG_EASY_CONTAINER" sh -c "$1"
  else
    sh -c "$1"
  fi
}

relay_copy_conf() {
  [[ -f "$RELAY_EXIT_CONF" ]] || die "relay config not found: $RELAY_EXIT_CONF"
  install -d -m 0755 /etc/wireguard
  install -m 0600 "$RELAY_EXIT_CONF" "/etc/wireguard/${RELAY_EXIT_IF}.conf"

  if [[ -n "$WG_EASY_CONTAINER" && "$WG_EASY_CONTAINER" != "host" ]]; then
    command -v docker >/dev/null 2>&1 || die "docker is required when WG_EASY_CONTAINER is set"
    docker cp "/etc/wireguard/${RELAY_EXIT_IF}.conf" "$WG_EASY_CONTAINER:/etc/wireguard/${RELAY_EXIT_IF}.conf"
    relay_exec "chmod 600 '/etc/wireguard/${RELAY_EXIT_IF}.conf'"
  fi
}

relay_ensure_forward() {
  sysctl -w net.ipv4.ip_forward=1 >/dev/null
  echo "net.ipv4.ip_forward=1" > /etc/sysctl.d/99-wg-captive-relay.conf
  relay_exec "sysctl -w net.ipv4.ip_forward=1 >/dev/null 2>&1 || true"
}

relay_tunnel_up() {
  relay_copy_conf
  relay_exec "wg-quick down '$RELAY_EXIT_IF' 2>/dev/null || true"
  relay_exec "wg-quick up '$RELAY_EXIT_IF'"
  echo "relay_tunnel: up"
}

relay_tunnel_down() {
  relay_exec "wg-quick down '$RELAY_EXIT_IF' 2>/dev/null || true"
  echo "relay_tunnel: down"
}

relay_route_off() {
  relay_exec "
while ip rule del from '$RELAY_CLIENT_SUBNET' table '$RELAY_ROUTE_TABLE' 2>/dev/null; do :; done
ip route flush table '$RELAY_ROUTE_TABLE' 2>/dev/null || true
while iptables -t nat -D POSTROUTING -s '$RELAY_CLIENT_SUBNET' -o '$RELAY_EXIT_IF' -j MASQUERADE 2>/dev/null; do :; done
while iptables -D FORWARD -j WG_RELAY 2>/dev/null; do :; done
iptables -F WG_RELAY 2>/dev/null || true
iptables -X WG_RELAY 2>/dev/null || true
" || true
  rm -f "$RELAY_ROUTE_FLAG"
  echo "relay_route: disabled"
}

relay_route_on() {
  [[ -f "$RELAY_EXIT_CONF" ]] || die "import relay exit config before enabling route"
  relay_ensure_forward
  relay_exec "ip link show '$RELAY_EXIT_IF' >/dev/null 2>&1" || relay_tunnel_up
  relay_route_off >/dev/null 2>&1 || true
  relay_exec "
iptables -N WG_RELAY 2>/dev/null || true
iptables -F WG_RELAY
iptables -C FORWARD -j WG_RELAY 2>/dev/null || iptables -A FORWARD -j WG_RELAY
iptables -A WG_RELAY -s '$RELAY_CLIENT_SUBNET' -o '$RELAY_EXIT_IF' -j ACCEPT
ip route add default dev '$RELAY_EXIT_IF' table '$RELAY_ROUTE_TABLE'
ip rule add from '$RELAY_CLIENT_SUBNET' table '$RELAY_ROUTE_TABLE'
iptables -t nat -A POSTROUTING -s '$RELAY_CLIENT_SUBNET' -o '$RELAY_EXIT_IF' -j MASQUERADE
"
  touch "$RELAY_ROUTE_FLAG"
  echo "relay_route: enabled"
}

relay_restart() {
  relay_tunnel_down
  relay_tunnel_up
  if [[ -f "$RELAY_ROUTE_FLAG" ]]; then
    relay_route_on
  fi
}

relay_restore() {
  if [[ -f "$RELAY_ROUTE_FLAG" ]]; then
    relay_tunnel_up || true
    relay_route_on || true
  fi
}

relay_enable() {
  relay_tunnel_up
  relay_route_on
}

relay_disable() {
  relay_route_off
  relay_tunnel_down
}

relay_delete_config() {
  local tunnel_on=0
  local route_on=0

  if relay_exec "ip link show '$RELAY_EXIT_IF' >/dev/null 2>&1"; then
    tunnel_on=1
  fi

  if relay_exec "ip rule show | grep -q 'from $RELAY_CLIENT_SUBNET lookup $RELAY_ROUTE_TABLE'"; then
    route_on=1
  fi

  if [[ "$tunnel_on" == "1" && "$route_on" == "1" ]]; then
    die "turn off relay tunnel and route before deleting exit config"
  elif [[ "$tunnel_on" == "1" ]]; then
    die "turn off relay tunnel before deleting exit config"
  elif [[ "$route_on" == "1" ]]; then
    die "turn off relay route before deleting exit config"
  fi

  rm -f "$RELAY_EXIT_CONF" "/etc/wireguard/${RELAY_EXIT_IF}.conf"
  relay_exec "rm -f '/etc/wireguard/${RELAY_EXIT_IF}.conf'"
  echo "relay_config: deleted"
}

relay_status() {
  echo "relay_config: $RELAY_EXIT_CONF"
  echo "relay_imported: $([[ -f "$RELAY_EXIT_CONF" ]] && echo yes || echo no)"
  echo "relay_container: ${WG_EASY_CONTAINER:-host}"
  echo "relay_exit_if: $RELAY_EXIT_IF"
  echo "relay_client_subnet: $RELAY_CLIENT_SUBNET"
  echo "relay_route_table: $RELAY_ROUTE_TABLE"
  echo
  echo "=== Tunnel ==="
  if relay_exec "ip link show '$RELAY_EXIT_IF' >/dev/null 2>&1"; then
    echo "tunnel: UP"
    relay_exec "wg show '$RELAY_EXIT_IF' 2>/dev/null || true"
  else
    echo "tunnel: DOWN"
  fi
  echo
  echo "=== Route ==="
  if relay_exec "ip rule show | grep -q 'from $RELAY_CLIENT_SUBNET lookup $RELAY_ROUTE_TABLE'"; then
    echo "route: ENABLED"
  else
    echo "route: DISABLED"
  fi
  echo
  echo "=== Route table $RELAY_ROUTE_TABLE ==="
  relay_exec "ip route show table '$RELAY_ROUTE_TABLE' 2>/dev/null || true"
  echo
  echo "=== NAT ==="
  relay_exec "iptables -t nat -S POSTROUTING | grep '$RELAY_EXIT_IF' || true"
  echo
  echo "=== Relay chain ==="
  relay_exec "iptables -S WG_RELAY 2>/dev/null || true"
}
extract_ips() {
  grep -Eo '([0-9]{1,3}\.){3}[0-9]{1,3}' | awk '
    function valid(ip, parts, i) {
      split(ip, parts, ".")
      for (i = 1; i <= 4; i++) {
        if (parts[i] < 0 || parts[i] > 255) return 0
      }
      return 1
    }
    valid($1) { print $1 }
  ' | sort -u
}

fetch_expired_ips() {
  if [[ -n "$EXPIRED_URL" ]]; then
    if [[ -n "$API_TOKEN" ]]; then
      curl -fsS -H "Authorization: Bearer ${API_TOKEN}" "$EXPIRED_URL" | extract_ips
    else
      curl -fsS "$EXPIRED_URL" | extract_ips
    fi
    return
  fi

  if [[ -n "$EXPIRED_FILE" && -f "$EXPIRED_FILE" ]]; then
    extract_ips < "$EXPIRED_FILE"
    return
  fi

  true
}

sync_ipset() {
  local tmp_set="${IPSET_NAME}_next"

  ips create "$IPSET_NAME" hash:ip -exist
  ips create "$tmp_set" hash:ip -exist
  ips flush "$tmp_set"

  while IFS= read -r ip; do
    [[ -n "$ip" ]] && ips add "$tmp_set" "$ip" -exist
  done < <(fetch_expired_ips)

  ips swap "$tmp_set" "$IPSET_NAME"
  ips destroy "$tmp_set" >/dev/null 2>&1 || true
}

cleanup() {
  resolve_netns
  ipt -t nat -D PREROUTING -i "$WG_INTERFACE" -m set --match-set "$IPSET_NAME" src -j "$NAT_CHAIN" >/dev/null 2>&1 || true
  ipt -t nat -D PREROUTING -m set --match-set "$IPSET_NAME" src -j "$NAT_CHAIN" >/dev/null 2>&1 || true
  ipt -t filter -D FORWARD -i "$WG_INTERFACE" -m set --match-set "$IPSET_NAME" src -j "$FILTER_CHAIN" >/dev/null 2>&1 || true
  ipt -t filter -D FORWARD -m set --match-set "$IPSET_NAME" src -j "$FILTER_CHAIN" >/dev/null 2>&1 || true

  if ipt -t nat -nL "$NAT_CHAIN" >/dev/null 2>&1; then
    ipt -t nat -F "$NAT_CHAIN"
    ipt -t nat -X "$NAT_CHAIN"
  fi

  if ipt -t filter -nL "$FILTER_CHAIN" >/dev/null 2>&1; then
    ipt -t filter -F "$FILTER_CHAIN"
    ipt -t filter -X "$FILTER_CHAIN"
  fi

  ips destroy "$IPSET_NAME" >/dev/null 2>&1 || true
}

status() {
  resolve_netns
  echo "config: $CONFIG_FILE"
  echo "interface: $WG_INTERFACE"
  echo "ipset: $IPSET_NAME"
  echo "portal_ip: $PORTAL_IP"
  echo "wg_easy_container: ${WG_EASY_CONTAINER:-host}"
  echo "docker_dns_ip: ${DOCKER_DNS_IP:-disabled}"
  echo "netns_pid: ${NETNS_PID:-host}"
  echo
  ips list "$IPSET_NAME" 2>/dev/null || true
  echo
  ipt -t nat -S PREROUTING 2>/dev/null | grep "$NAT_CHAIN" || true
  ipt -t nat -S "$NAT_CHAIN" 2>/dev/null || true
  echo
  ipt -S FORWARD 2>/dev/null | grep "$FILTER_CHAIN" || true
  ipt -S "$FILTER_CHAIN" 2>/dev/null || true
}

sync_once() {
  require_root
  require_config
  ensure_tools
  ensure_firewall
  sync_ipset
}

run_loop() {
  sync_once
  while true; do
    sleep "$SYNC_INTERVAL"
    sync_once
  done
}

main() {
  local command="${1:-run}"

  case "$command" in
    run)
      run_loop
      ;;
    sync)
      sync_once
      ;;
    cleanup)
      require_root
      ensure_tools
      cleanup
      ;;
    status)
      status
      ;;
    relay-tunnel-up)
      require_root
      relay_tunnel_up
      ;;
    relay-tunnel-down)
      require_root
      relay_tunnel_down
      ;;
    relay-restart)
      require_root
      relay_restart
      ;;
    relay-enable)
      require_root
      relay_enable
      ;;
    relay-disable)
      require_root
      relay_disable
      ;;
    relay-delete-config)
      require_root
      relay_delete_config
      ;;
    relay-on)
      require_root
      relay_route_on
      ;;
    relay-off)
      require_root
      relay_route_off
      ;;
    relay-restore)
      require_root
      relay_restore
      ;;
    relay-status)
      relay_status
      ;;
    -h|--help|help)
      usage
      ;;
    *)
      usage
      exit 2
      ;;
  esac
}

main "$@"
